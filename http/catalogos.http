@baseUrl = http://localhost:8000/api/v1
@token = your_token_here

### =====================
### Catálogos
### =====================

### --- Acabados Tablero ---

### Listar acabados tablero
GET {{baseUrl}}/acabado-tableros
Authorization: Bearer {{token}}

### Ver acabado tablero
GET {{baseUrl}}/acabado-tableros/1
Authorization: Bearer {{token}}

### Crear acabado tablero
POST {{baseUrl}}/acabado-tableros
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Nuevo acabado tablero"
}

### Actualizar acabado tablero
PUT {{baseUrl}}/acabado-tableros/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Acabado actualizado"
}

### Eliminar acabado tablero
DELETE {{baseUrl}}/acabado-tableros/1
Authorization: Bearer {{token}}

###

### --- Tira LEDs ---

### Listar tira LEDs
GET {{baseUrl}}/tira-leds
Authorization: Bearer {{token}}

### Ver tira LED
GET {{baseUrl}}/tira-leds/1
Authorization: Bearer {{token}}

### Crear tira LED
POST {{baseUrl}}/tira-leds
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Tira LED RGB",
    "codigo": "TIRA_LED_001",
    "descripcion": "Tira LED RGB de 5 metros",
    "precio_unitario": 25.50,
    "unidades_por_metro": 5,
    "porcentaje_utilizacion": 3.052,
    "cantidad_compra": 4
}

### Actualizar tira LED
PUT {{baseUrl}}/tira-leds/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Tira LED RGBW",
    "precio_unitario": 30.00,
    "unidades_por_metro": 6,
    "cantidad_compra": 5
}

### Eliminar tira LED
DELETE {{baseUrl}}/tira-leds/1
Authorization: Bearer {{token}}

